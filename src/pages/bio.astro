---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="MaxFocos · Protocolo R1, Dra. Amanda e Dr. Eliézer"
  description="Acesse o Protocolo R1 (mentoria ENARE em CTBMF), as páginas da Dra. Amanda e do Dr. Eliézer, e fale direto com a equipe MaxFocos."
  image="/images/r1/studio-3.jpg"
>

<main class="bio">
  <div class="bio-col">

    <!-- ═══ HEADER / PERFIL ═══ -->
    <header class="bio-head">
      <img src="/images/r1/logo-maxfocos-vertical.png" alt="MaxFocos" class="bio-logo" width="130" height="130" />
      <span class="bio-tag"><span class="bio-tag-dot" aria-hidden="true"></span>Protocolo R1 · Aprovação em CTBMF</span>
    </header>

    <!-- ═══ REDES SOCIAIS ═══ -->
    <nav class="bio-social" aria-label="Redes sociais">
      <!-- TODO: trocar href="#" pelos perfis reais (Instagram, TikTok, YouTube, e-mail) -->
      <a href="#" class="bio-social-link" aria-label="Instagram" data-todo="instagram" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="#" class="bio-social-link" aria-label="TikTok" data-todo="tiktok" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4c.5 2.3 2.1 3.7 4.2 3.9v2.7c-1.5.1-2.9-.4-4.2-1.2v5.9a5.3 5.3 0 1 1-5.3-5.3c.3 0 .6 0 .9.1v2.8a2.5 2.5 0 1 0 1.7 2.4V4H15Z"/></svg>
      </a>
      <a href="#" class="bio-social-link" aria-label="YouTube" data-todo="youtube" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="6" width="19" height="12" rx="3.5"/><path d="M10.5 9.2 15 12l-4.5 2.8V9.2Z" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="https://wa.me/5511997311111" class="bio-social-link" aria-label="WhatsApp" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20l1.4-4a7.5 7.5 0 1 1 2.9 2.7L4 20Z"/><path d="M9 9.5c0 3 2.5 5.5 5.5 5.5.5 0 1-.4 1-.9 0-.2-.1-.4-.3-.5l-1.3-.6c-.2-.1-.5 0-.6.2l-.3.5c-1-.4-1.8-1.2-2.2-2.2l.5-.3c.2-.1.3-.4.2-.6l-.6-1.3c-.1-.2-.3-.3-.5-.3-.5 0-.9.5-.9 1Z" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="#" class="bio-social-link" aria-label="E-mail" data-todo="email">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m4 7 8 5.5L20 7"/></svg>
      </a>
    </nav>

    <!-- ═══ CARD DESTAQUE — PROTOCOLO R1 ═══ -->
    <a href="/" class="bio-card bio-card-feature">
      <span class="bio-card-kicker">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M12 2l1.8 5.2L19 9l-5.2 1.8L12 16l-1.8-5.2L5 9l5.2-1.8L12 2Z"/></svg>
        Método completo
      </span>
      <h2 class="bio-card-title">Protocolo R1</h2>
      <div class="bio-card-bottom">
        <p class="bio-card-desc">Acesso ao método completo de aprovação na residência em CTBMF.</p>
        <span class="bio-arrow bio-arrow-solid" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
        </span>
      </div>
    </a>

    <!-- ═══ CARDS MÉDICOS ═══ -->
    <div class="bio-duo">
      <a href="/dra-amanda" class="bio-card bio-card-mini">
        <div class="bio-mini-top">
          <h3>Dra. Amanda</h3>
          <span class="bio-arrow bio-arrow-ghost" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
          </span>
        </div>
        <p class="bio-mini-desc">Cirurgiã Bucomaxilofacial</p>
      </a>

      <a href="/dr-eliezer" class="bio-card bio-card-mini">
        <div class="bio-mini-top">
          <h3>Dr. Eliézer</h3>
          <span class="bio-arrow bio-arrow-ghost" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
          </span>
        </div>
        <p class="bio-mini-desc">Cirurgião Bucomaxilofacial</p>
      </a>
    </div>

    <!-- ═══ CTA WHATSAPP ═══ -->
    <a href="https://wa.me/5511997311111?text=Ol%C3%A1!%20Gostaria%20de%20falar%20com%20a%20equipe%20MaxFocos." class="bio-whatsapp" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20l1.4-4a7.5 7.5 0 1 1 2.9 2.7L4 20Z"/><path d="M9 9.5c0 3 2.5 5.5 5.5 5.5.5 0 1-.4 1-.9 0-.2-.1-.4-.3-.5l-1.3-.6c-.2-.1-.5 0-.6.2l-.3.5c-1-.4-1.8-1.2-2.2-2.2l.5-.3c.2-.1.3-.4.2-.6l-.6-1.3c-.1-.2-.3-.3-.5-.3-.5 0-.9.5-.9 1Z" fill="currentColor" stroke="none"/></svg>
      Fale com a nossa equipe
    </a>

    <!-- ═══ FOOTER ═══ -->
    <footer class="bio-foot">© MaxFocos 2026 · Todos os direitos reservados</footer>

  </div>
</main>

</Layout>

<style>
/* ═══════════════════════════════════════════
   LINK NA BIO — MAXFOCOS
   Mobile-first · dark · Neue Kaine + Geist Mono
   ═══════════════════════════════════════════ */
:root {
  --bio-bg: #0A0A0A;
  --bio-card: #161616;
  --bio-card-2: #101010;
  --bio-border: #262626;
  --bio-yellow: #FDE102;
  --bio-white: #FFFFFF;
  --bio-gray: #9A9A9A;
  --bio-title: 'Neue Kaine', system-ui, sans-serif;
  --bio-mono: 'Geist Mono', 'Courier New', monospace;
  --bio-ease: cubic-bezier(0.16, 1, 0.3, 1);
}

html { background: var(--bio-bg); }
body { background: var(--bio-bg); color: var(--bio-white); font-family: var(--bio-mono); }

.bio {
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: clamp(2.5rem, 8vh, 5rem) 1.25rem;
  box-sizing: border-box;
}
.bio-col {
  width: 100%;
  max-width: 460px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── HEADER ── */
.bio-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.5rem;
}
.bio-logo {
  width: clamp(96px, 26vw, 120px);
  height: auto;
  opacity: 0.96;
}
.bio-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--bio-mono);
  font-size: 0.8125rem;
  letter-spacing: 0.02em;
  color: var(--bio-gray);
}
.bio-tag-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--bio-yellow);
  box-shadow: 0 0 10px rgba(253,225,2,0.7);
}

/* ── REDES SOCIAIS ── */
.bio-social {
  display: flex;
  gap: 0.5rem;
  margin: 1.75rem 0 2rem;
}
.bio-social-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  color: var(--bio-white);
  border: 1px solid transparent;
  transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s var(--bio-ease);
}
.bio-social-link:hover {
  color: var(--bio-yellow);
  border-color: rgba(253,225,2,0.3);
  background: rgba(253,225,2,0.06);
  transform: translateY(-2px);
}

/* ── CARDS (base) ── */
.bio-card {
  position: relative;
  display: block;
  width: 100%;
  text-decoration: none;
  color: var(--bio-white);
  border: 1px solid var(--bio-border);
  border-radius: 20px;
  transition: transform 0.3s var(--bio-ease), border-color 0.3s, box-shadow 0.3s;
  box-sizing: border-box;
}
.bio-card:hover {
  transform: translateY(-3px);
  border-color: rgba(253,225,2,0.35);
  box-shadow: 0 20px 45px -25px rgba(0,0,0,0.8);
}

/* Card destaque */
.bio-card-feature {
  background:
    radial-gradient(120% 90% at 50% -10%, rgba(253,225,2,0.06), transparent 60%),
    linear-gradient(180deg, #1B1B1B 0%, #121212 100%);
  padding: 1.5rem;
  min-height: 230px;
  display: flex;
  flex-direction: column;
  margin-bottom: 1rem;
}
.bio-card-kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-family: var(--bio-mono);
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--bio-yellow);
}
.bio-card-title {
  font-family: var(--bio-title);
  font-weight: 800;
  font-size: clamp(1.75rem, 7vw, 2.25rem);
  letter-spacing: -0.02em;
  color: var(--bio-white);
  margin: auto 0 0;
}
.bio-card-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1rem;
  margin-top: 1.25rem;
}
.bio-card-desc {
  font-family: var(--bio-mono);
  font-size: 0.8125rem;
  line-height: 1.55;
  color: var(--bio-gray);
  margin: 0;
  max-width: 78%;
}

/* Arrows */
.bio-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.25s var(--bio-ease);
}
.bio-arrow-solid {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--bio-yellow);
  color: #111;
}
.bio-arrow-ghost {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 1px solid var(--bio-border);
  color: var(--bio-white);
}
.bio-card:hover .bio-arrow { transform: translate(2px, -2px); }
.bio-card:hover .bio-arrow-ghost { border-color: var(--bio-yellow); color: var(--bio-yellow); }

/* Cards médicos (duo) */
.bio-duo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  width: 100%;
  margin-bottom: 1.75rem;
}
.bio-card-mini {
  background: var(--bio-card);
  padding: 1.25rem;
  min-height: 130px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.bio-mini-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.5rem;
}
.bio-card-mini h3 {
  font-family: var(--bio-title);
  font-weight: 700;
  font-size: clamp(1.125rem, 5vw, 1.375rem);
  letter-spacing: -0.01em;
  color: var(--bio-white);
  margin: 0;
}
.bio-mini-desc {
  font-family: var(--bio-mono);
  font-size: 0.75rem;
  line-height: 1.5;
  color: var(--bio-gray);
  margin: 0;
}

/* ── CTA WHATSAPP ── */
.bio-whatsapp {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.65rem;
  width: 100%;
  padding: 1.1rem 1.5rem;
  border-radius: 100px;
  background: var(--bio-yellow);
  color: #111;
  font-family: var(--bio-title);
  font-weight: 700;
  font-size: 1.0625rem;
  text-decoration: none;
  box-sizing: border-box;
  transition: transform 0.25s var(--bio-ease), box-shadow 0.25s var(--bio-ease);
}
.bio-whatsapp:hover {
  transform: translateY(-2px);
  box-shadow: 0 16px 40px -12px rgba(253,225,2,0.4);
}

/* ── FOOTER ── */
.bio-foot {
  margin-top: 2rem;
  font-family: var(--bio-mono);
  font-size: 0.6875rem;
  color: rgba(154,154,154,0.7);
  text-align: center;
  letter-spacing: 0.02em;
}

/* ── telas muito estreitas ── */
@media (max-width: 340px) {
  .bio-duo { grid-template-columns: 1fr; }
}
</style>
