  .r1-pilar { border-right: none; border-bottom: 1px solid var(--r1-darkgray); }
  .r1-pilar:nth-child(2n) { border-right: none; }
  .r1-pilar:nth-child(odd) { border-right: 1px solid var(--r1-darkgray); }
  .r1-pilar:nth-last-child(-n+2) { border-bottom: none; }
  .r1-comp-table { grid-template-columns: 1fr; }
  .r1-mentores-grid { grid-template-columns: 1fr; }
  .r1-aprovados-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .r1-nav-links { display: none; }
  .r1-nav-cta { display: none; }
  .r1-burger { display: flex; }

  /* Mobile nav open */
  .r1-nav-links.r1-nav-open {
    display: flex;
    flex-direction: column;
    position: fixed;
    inset: 72px 0 0;
    background: var(--r1-bg);
    padding: 2.5rem var(--r1-gutter);
    gap: 1.75rem;
    z-index: 99;
    overflow-y: auto;
  }
  .r1-nav-links.r1-nav-open a { font-size: 1.125rem; color: var(--r1-white); }

  .r1-hero-h1 { font-size: clamp(2rem, 8vw, 3.5rem); }
  .r1-pilares-grid { grid-template-columns: 1fr; }
  .r1-pilar { border-right: none !important; border-bottom: 1px solid var(--r1-darkgray); }
  .r1-pilar:last-child { border-bottom: none; }

  .r1-hero-ctas { flex-direction: column; }
  .r1-hero-ctas .r1-btn { width: 100%; justify-content: center; }

  .r1-footer-top { flex-direction: column; gap: 0.5rem; }
}

@media (max-width: 480px) {
  .r1-aprovados-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .r1-hero-meta { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
  .r1-dot { display: none; }
  .r1-destaque { max-height: 300px; }
}
</style>

<script>
  // Nav scroll effect
  const nav = document.getElementById('r1nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    });
  }

  // Mobile burger menu
  const burger = document.getElementById('r1-burger');
  const links = document.getElementById('r1-nav-links');
  if (burger && links) {
    burger.addEventListener('click', () => {
      const isOpen = links.classList.toggle('r1-nav-open');
      burger.setAttribute('aria-expanded', String(isOpen));
    });
    // Close on link click
    links.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        links.classList.remove('r1-nav-open');
        burger.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('r1-visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.r1-arm, .r1-pilar, .r1-mentor-card, .r1-aprovado-card, .r1-faq-item, .r1-solucao, .r1-comp-col, .r1-mentor-quote').forEach(el => {
    el.classList.add('r1-reveal');
    observer.observe(el);
  });
</script>

<style>
  /* Reveal animations */
  .r1-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s var(--r1-ease), transform 0.8s var(--r1-ease);
  }
  .r1-visible {
    opacity: 1;
    transform: none;
  }

  /* Staggered delays for grid items */
  .r1-pilar:nth-child(2).r1-reveal,
  .r1-arm:nth-child(2).r1-reveal,
  .r1-mentor-card:nth-child(2).r1-reveal,
  .r1-aprovado-card:nth-child(2).r1-reveal { transition-delay: 0.08s; }

  .r1-pilar:nth-child(3).r1-reveal,
  .r1-aprovado-card:nth-child(3).r1-reveal { transition-delay: 0.16s; }

  .r1-pilar:nth-child(4).r1-reveal,
  .r1-aprovado-card:nth-child(4).r1-reveal { transition-delay: 0.24s; }

  .r1-comp-col:nth-child(2).r1-reveal { transition-delay: 0.1s; }
</style>
