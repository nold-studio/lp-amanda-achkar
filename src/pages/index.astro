  padding: 1.5rem;
  align-items: center;
}

/* Custom Player Container */
.r1-video-container {
  position: relative;
  width: 100%;
  aspect-ratio: 9/16;
  border-radius: 10px;
  overflow: hidden;
  background: #000;
}
.r1-custom-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.r1-video-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: opacity 0.3s;
}
.r1-video-container.playing .r1-video-overlay {
  opacity: 0;
  pointer-events: none;
}
.r1-play-btn {
  background: var(--r1-yellow);
  color: #111;
  border: none;
  border-radius: 50%;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.2s;
  box-shadow: 0 4px 20px rgba(253, 225, 18, 0.4);
}
.r1-play-btn:hover {
  transform: scale(1.1);
}

/* Controls */
.r1-video-controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}
.r1-video-container:hover .r1-video-controls,
.r1-video-container.playing:hover .r1-video-controls {
  opacity: 1;
  pointer-events: auto;
}
.r1-video-controls button {
  background: none;
