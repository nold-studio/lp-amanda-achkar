</style>

<script>
  // Nav scroll effect
  const nav = document.getElementById('r1nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    });
  }

  // Mobile burger menu
  const burger = document.getElementById('r1-burger');
  const links = document.getElementById('r1-nav-links');
  if (burger && links) {
    burger.addEventListener('click', () => {
      const isOpen = links.classList.toggle('r1-nav-open');
      burger.setAttribute('aria-expanded', String(isOpen));
    });
    // Close on link click
    links.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        links.classList.remove('r1-nav-open');
        burger.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Video Players Custom Logic
  const videoContainers = document.querySelectorAll('.r1-video-container');

  videoContainers.forEach(container => {
    const video = container.querySelector('.r1-custom-video') as HTMLVideoElement;
    const overlay = container.querySelector('.r1-video-overlay') as HTMLDivElement;
    const playPauseBtn = container.querySelector('.r1-control-play-pause') as HTMLButtonElement;
    const progressBar = container.querySelector('.r1-video-progress-bar') as HTMLDivElement;
    const progress = container.querySelector('.r1-video-progress') as HTMLDivElement;
    const muteBtn = container.querySelector('.r1-control-mute') as HTMLButtonElement;

    const iconPlay = playPauseBtn.querySelector('.icon-play') as HTMLElement;
    const iconPause = playPauseBtn.querySelector('.icon-pause') as HTMLElement;

    if (!video) return;

    // Toggle Play/Pause
    const togglePlay = () => {
      if (video.paused) {
        // Pause all other videos
        document.querySelectorAll('.r1-custom-video').forEach(v => {
          if (v !== video) {
            (v as HTMLVideoElement).pause();
            v.parentElement?.classList.remove('playing');
          }
        });

        video.play();
        container.classList.add('playing');
        iconPlay.style.display = 'none';
        iconPause.style.display = 'block';
      } else {
        video.pause();
        container.classList.remove('playing');
        iconPlay.style.display = 'block';
        iconPause.style.display = 'none';
      }
    };

    overlay.addEventListener('click', togglePlay);
    playPauseBtn.addEventListener('click', togglePlay);

    // Mute/Unmute
    muteBtn.addEventListener('click', () => {
      video.muted = !video.muted;
      muteBtn.style.opacity = video.muted ? '0.5' : '1';
    });

    // Update progress bar
    video.addEventListener('timeupdate', () => {
      const percentage = (video.currentTime / video.duration) * 100;
      progress.style.width = percentage + '%';
    });

    // Click on progress bar to scrub
    progressBar.addEventListener('click', (e) => {
      const rect = progressBar.getBoundingClientRect();
      const pos = (e.clientX - rect.left) / rect.width;
      video.currentTime = pos * video.duration;
    });
  });

  // Reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('r1-visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.r1-arm, .r1-pilar, .r1-mentor-info-item, .r1-aprovado-card-foto, .r1-faq-item, .r1-solucao, .r1-comp-col, .r1-depoimento-card, .r1-wa-card').forEach(el => {
    el.classList.add('r1-reveal');
    observer.observe(el);
  });

  // ═══ FORMULÁRIO DE LEAD (captura + atribuição + CRM + GTM + WhatsApp) ═══
  declare global {
    interface Window { dataLayer?: Record<string, any>[] }
  }

  const R1_WHATSAPP_NUMBER = '5511997311111';
  const R1_WEBHOOK_URL = 'https://webhook.kaju.dev.br/webhook/lp-enare';
  const R1_ORIGEM = 'Landing Page - Protocolo R1';
  const R1_PROJETO = 'MaxFocos - Mentoria ENARE';
  const R1_MENSAGEM_BASE = 'Olá! Gostaria de conhecer melhor a Mentoria Protocolo R1 (ENARE).';

  function r1GetCookie(name: string): string {
    if (typeof document === 'undefined') return '';
    for (const cookie of document.cookie.split(';')) {
      const [cookieName, ...cookieValue] = cookie.trim().split('=');
      if (cookieName === name) return decodeURIComponent(cookieValue.join('='));
    }
    return '';
  }

  function r1GetGaClientId(): string {
    const gaCookie = r1GetCookie('_ga');
    if (!gaCookie) return '';
    const parts = gaCookie.split('.');
    if (parts.length < 4) return '';
    return `${parts[parts.length - 2]}.${parts[parts.length - 1]}`;
  }

  function r1GetCurrentUrlParams(): Record<string, string> {
    const params = new URLSearchParams(window.location.search);
    return {
      utm_source: params.get('utm_source') || '',
      utm_medium: params.get('utm_medium') || '',
      utm_campaign: params.get('utm_campaign') || '',
      utm_content: params.get('utm_content') || '',
      utm_term: params.get('utm_term') || '',
      gclid: params.get('gclid') || '',
      gbraid: params.get('gbraid') || '',
      wbraid: params.get('wbraid') || '',
      fbclid: params.get('fbclid') || '',
    };
  }

  function r1SaveAttributionData(): void {
    const currentParams = r1GetCurrentUrlParams();
    const hasAttribution = Object.values(currentParams).some((v) => v !== '');
    if (!hasAttribution) return;
    try {
      const payload = { ...currentParams, landing_page: window.location.href, captured_at: new Date().toISOString() };
      if (!localStorage.getItem('mf_first_touch_attribution')) {
        localStorage.setItem('mf_first_touch_attribution', JSON.stringify(payload));
      }
      localStorage.setItem('mf_last_touch_attribution', JSON.stringify(payload));
    } catch (error) {
      console.warn('Não foi possível salvar a atribuição:', error);
    }
  }

  function r1GetStoredAttribution(storageKey: string): Record<string, string> {
    try {
      const stored = localStorage.getItem(storageKey);
      return stored ? JSON.parse(stored) : {};
    } catch {
      return {};
    }
  }

  function r1GetAttributionData() {
    const currentParams = r1GetCurrentUrlParams();
    const lastTouch = r1GetStoredAttribution('mf_last_touch_attribution');
    const firstTouch = r1GetStoredAttribution('mf_first_touch_attribution');
    const fbclid = currentParams.fbclid || lastTouch.fbclid || firstTouch.fbclid || '';
    const storedFbc = r1GetCookie('_fbc');
    const generatedFbc = !storedFbc && fbclid ? `fb.1.${Date.now()}.${fbclid}` : '';

    return {
      utm_source: currentParams.utm_source || lastTouch.utm_source || firstTouch.utm_source || '',
      utm_medium: currentParams.utm_medium || lastTouch.utm_medium || firstTouch.utm_medium || '',
      utm_campaign: currentParams.utm_campaign || lastTouch.utm_campaign || firstTouch.utm_campaign || '',
      utm_content: currentParams.utm_content || lastTouch.utm_content || firstTouch.utm_content || '',
      utm_term: currentParams.utm_term || lastTouch.utm_term || firstTouch.utm_term || '',
      gclid: currentParams.gclid || lastTouch.gclid || firstTouch.gclid || '',
      gbraid: currentParams.gbraid || lastTouch.gbraid || firstTouch.gbraid || '',
      wbraid: currentParams.wbraid || lastTouch.wbraid || firstTouch.wbraid || '',
      fbclid,
      fbp: r1GetCookie('_fbp'),
      fbc: storedFbc || generatedFbc,
      ga_client_id: r1GetGaClientId(),
    };
  }

  function r1CreateEventId(): string {
    if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
      return `lead_${crypto.randomUUID()}`;
    }
    return `lead_${Date.now()}_${Math.random().toString(36).substring(2, 12)}`;
  }

  function r1FormatPhone(value: string): string {
    const cleaned = value.replace(/\D/g, '').slice(0, 11);
    if (cleaned.length <= 2) return cleaned;
    if (cleaned.length <= 6) return `(${cleaned.slice(0, 2)}) ${cleaned.slice(2)}`;
    if (cleaned.length <= 10) return `(${cleaned.slice(0, 2)}) ${cleaned.slice(2, 6)}-${cleaned.slice(6)}`;
    return `(${cleaned.slice(0, 2)}) ${cleaned.slice(2, 7)}-${cleaned.slice(7)}`;
  }

  function r1GetDeviceType(): string {
    const ua = navigator.userAgent;
    if (/tablet|ipad|playbook|silk/i.test(ua)) return 'Tablet';
    if (/Mobi|Android|iPhone|iPod/i.test(ua)) return 'Mobile';
    return 'Desktop';
  }

  async function r1SendToCrm(payload: Record<string, any>): Promise<void> {
    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 5000);
    try {
      const response = await fetch(R1_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: controller.signal,
        keepalive: true,
      });
      if (!response.ok) throw new Error(`Webhook respondeu com status ${response.status}`);
    } finally {
      window.clearTimeout(timeout);
    }
  }

  r1SaveAttributionData();

  const leadForm = document.getElementById('r1-lead-form') as HTMLFormElement | null;
  const phoneInput = document.getElementById('r1-telefone') as HTMLInputElement | null;
  const submitBtn = document.getElementById('r1-form-submit') as HTMLButtonElement | null;
  const submitBtnText = submitBtn?.querySelector('.r1-form-submit-text') as HTMLElement | null;
  const errorEl = document.getElementById('r1-form-error') as HTMLElement | null;

  if (phoneInput) {
    phoneInput.addEventListener('input', () => {
      phoneInput.value = r1FormatPhone(phoneInput.value);
    });
  }

  if (leadForm && phoneInput && submitBtn && submitBtnText && errorEl) {
    leadForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (submitBtn.disabled) return;

      errorEl.hidden = true;
      errorEl.textContent = '';

      const formData = new FormData(leadForm);
      const nome = String(formData.get('nome') || '').trim();
      const telefone = String(formData.get('telefone') || '');
      const telefoneLimpo = telefone.replace(/\D/g, '');
      const preparacaoResidencia = String(formData.get('preparacao_residencia') || '');
      const cursoPreparatorio = String(formData.get('curso_preparatorio') || '');

      if (!nome || !telefoneLimpo || !preparacaoResidencia || !cursoPreparatorio) {
        errorEl.textContent = 'Por favor, preencha todos os campos.';
        errorEl.hidden = false;
        return;
      }
      if (telefoneLimpo.length < 10) {
        errorEl.textContent = 'Digite um número de WhatsApp válido, incluindo o DDD.';
        errorEl.hidden = false;
        return;
      }

      submitBtn.disabled = true;
      submitBtnText.textContent = 'Enviando...';

      const attribution = r1GetAttributionData();
      const eventId = r1CreateEventId();
      const eventTime = Math.floor(Date.now() / 1000);
      const submittedAt = new Date().toISOString();

      const mensagem = `${R1_MENSAGEM_BASE}

Nome: ${nome}
WhatsApp: ${telefone}
Preparação para a residência: ${preparacaoResidencia}
Uso de curso preparatório: ${cursoPreparatorio}`;

      const pageData = {
        page_location: window.location.href,
        page_path: window.location.pathname,
        page_title: document.title,
        referrer: document.referrer || '',
      };
      const technicalData = {
        dispositivo: r1GetDeviceType(),
        navegador: navigator.userAgent,
        idioma: navigator.language || '',
        timezone: Intl.DateTimeFormat().resolvedOptions().timeZone || '',
      };

      const crmPayload = {
        event_name: 'Lead',
        event_id: eventId,
        event_time: eventTime,
        data_envio: submittedAt,
        formulario: 'FormMentoriaR1',
        origem: R1_ORIGEM,
        projeto: R1_PROJETO,
        nome,
        telefone,
        telefone_limpo: telefoneLimpo,
        preparacao_residencia: preparacaoResidencia,
        curso_preparatorio: cursoPreparatorio,
        mensagem_whatsapp: mensagem,
        ...pageData,
        ...technicalData,
        ...attribution,
      };

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'formulario_mentoria_r1_enviado',
        event_name: 'Lead',
        event_id: eventId,
        event_time: eventTime,
        form_id: 'FormMentoriaR1',
        form_name: 'Formulário Mentoria Protocolo R1',
        form_origem: R1_ORIGEM,
        form_projeto: R1_PROJETO,
        form_nome: nome,
        form_telefone: telefone,
        form_telefone_limpo: telefoneLimpo,
        form_preparacao_residencia: preparacaoResidencia,
        form_curso_preparatorio: cursoPreparatorio,
        user_data: { full_name: nome, phone_number: telefoneLimpo },
        attribution,
        page_location: pageData.page_location,
        page_path: pageData.page_path,
        page_title: pageData.page_title,
        referrer: pageData.referrer,
        dispositivo: technicalData.dispositivo,
        navegador: technicalData.navegador,
        idioma: technicalData.idioma,
        timezone: technicalData.timezone,
      });

      try {
        await r1SendToCrm(crmPayload);
      } catch (error) {
        console.error('Não foi possível enviar o lead ao CRM:', error);
        window.dataLayer.push({
          event: 'formulario_mentoria_r1_erro_crm',
          event_id: eventId,
          form_id: 'FormMentoriaR1',
          form_origem: R1_ORIGEM,
        });
      }

      const numeroLimpo = R1_WHATSAPP_NUMBER.replace(/\D/g, '');
      const whatsappUrl = `https://wa.me/${numeroLimpo}?text=${encodeURIComponent(mensagem)}`;
      window.open(whatsappUrl, '_blank', 'noopener,noreferrer');

      submitBtn.disabled = false;
      submitBtnText.textContent = 'Iniciar contato';
    });
  }
</script>

<style>
  /* Reveal animations */
  .r1-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s var(--r1-ease), transform 0.8s var(--r1-ease);
  }
  .r1-visible {
    opacity: 1;
    transform: none;
  }

  /* Staggered delays for grid items */
  .r1-pilar:nth-child(2).r1-reveal,
  .r1-arm:nth-child(2).r1-reveal,
  .r1-mentor-info-item:nth-child(2).r1-reveal,
  .r1-wa-card:nth-child(2).r1-reveal,
  .r1-aprovado-card-foto:nth-child(2).r1-reveal { transition-delay: 0.08s; }

  .r1-pilar:nth-child(3).r1-reveal,
  .r1-wa-card:nth-child(3).r1-reveal,
  .r1-aprovado-card-foto:nth-child(3).r1-reveal { transition-delay: 0.16s; }

  .r1-pilar:nth-child(4).r1-reveal,
  .r1-wa-card:nth-child(4).r1-reveal,
  .r1-aprovado-card-foto:nth-child(4).r1-reveal { transition-delay: 0.24s; }

  .r1-comp-col:nth-child(2).r1-reveal { transition-delay: 0.1s; }
</style>
