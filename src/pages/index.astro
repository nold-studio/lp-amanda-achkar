  background: var(--r1-bg);
}
.r1-comp-table {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin-top: 2.75rem;
}
.r1-comp-col {
  border-radius: 14px;
  padding: 2rem 1.75rem;
}
.r1-comp-old {
  background: var(--r1-surface);
  border: 1px solid var(--r1-darkgray);
}
.r1-comp-new {
